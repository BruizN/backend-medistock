@startuml
set separator none
title Medistock E-Commerce - API RESTful (FastAPI) - Components

top to bottom direction

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Component>

System(PasareladePagos, "Pasarela de Pagos", $descr="Procesa pagos (Webpay/MercadoPago).", $tags="", $link="")
System(APIdeDivisas, "API de Divisas", $descr="Convierte moneda en tiempo real.", $tags="", $link="")

Container_Boundary("MedistockECommerce.APIRESTfulFastAPI_boundary", "API RESTful (FastAPI)", $tags="") {
  Component(MedistockECommerce.APIRESTfulFastAPI.AuthModule, "Auth Module", $techn="Python/FastAPI Router", $descr="Gestiona JWT y autenticación", $tags="", $link="")
  Component(MedistockECommerce.APIRESTfulFastAPI.InventoryModule, "Inventory Module", $techn="Python/FastAPI Router", $descr="Gestiona productos y stock", $tags="", $link="")
  Component(MedistockECommerce.APIRESTfulFastAPI.OrdersModule, "Orders Module", $techn="Python/FastAPI Router", $descr="Gestiona pagos y órdenes", $tags="", $link="")
}

Rel(MedistockECommerce.APIRESTfulFastAPI.OrdersModule, MedistockECommerce.APIRESTfulFastAPI.InventoryModule, "Verifica y descuenta stock", $techn="", $tags="", $link="")
Rel(MedistockECommerce.APIRESTfulFastAPI.OrdersModule, PasareladePagos, "Inicia y valida pagos", $techn="REST/HTTPS", $tags="", $link="")
Rel(MedistockECommerce.APIRESTfulFastAPI.OrdersModule, APIdeDivisas, "Solicita conversión", $techn="REST/HTTPS", $tags="", $link="")
Rel(MedistockECommerce.APIRESTfulFastAPI.AuthModule, MedistockECommerce.APIRESTfulFastAPI.InventoryModule, "Verifica permisos", $techn="", $tags="", $link="")

SHOW_LEGEND(true)
@enduml